# ===========================================
# Code Intelligence RAG - Environment Variables
# ===========================================
# Copie este arquivo para .env e preencha:
#   copy .env.example .env
# ===========================================

# OpenAI API Key (obrigatório)
# Pegue a sua em: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Modelo para geração de respostas
# gpt-4o-mini é barato e muito bom para code QA
LLM_MODEL=gpt-4o-mini

# Modelo para embeddings
# text-embedding-3-small é barato e eficiente
EMBEDDING_MODEL=text-embedding-3-small

# Diretório onde o ChromaDB persiste os dados
CHROMA_PERSIST_DIR=./data/chromadb
